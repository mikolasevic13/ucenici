@model Razred

@if (Model != null)
{
	<h3> Razred: @Model.RazredNaziv </h3>
}

<form method="post" asp-controller="razredi" asp-action="edit">
	<input type="hidden" asp-for="RazredId"/>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="RazredNaziv" class=" col-form-label"></label>
		</div>

		<div class="col-6">
			<input type="text" asp-for="RazredNaziv" class="form-control"/>
		</div>
	</div>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="Razrednik" class=" col-form-label"></label>
		</div>

		<div class="col-6">
			<input type="text" asp-for="Razrednik" class="form-control" />
		</div>
	</div>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="RazredBrojUcenika" class=" col-form-label"></label>
		</div>

		<div class="col-6">
			<input type="number" asp-for="RazredBrojUcenika" class="form-control" />
		</div>
	</div>
	
	<div class="row mb-3">
		<div class="col-2">
			
		</div>

		<div class="col-6">
			<input type="submit" class="btn btn-primary" value="Save" />
		</div>
	</div>

</form>

