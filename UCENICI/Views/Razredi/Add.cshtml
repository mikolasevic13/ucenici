@model Razred

@section title{
@if (Model != null)
{
	<h3> Dodajte razred </h3>
}
}

<form method="post" asp-controller="razredi" asp-action="add">
	

	@* Dodao poruku o pogrešci - Error message *@
	<div class="text-bg-danger" asp-validation-summary="All"></div>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="RazredNaziv" class=" col-form-label">Razred</label>
		</div>

		<div class="col-6">
			<input type="text" asp-for="RazredNaziv" class="form-control"/>
		</div>

		<div class="col">
			<span class="text-danger" asp-validation-for="RazredNaziv"></span>
		</div>
	</div>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="Razrednik" class=" col-form-label">Razrednik</label>
		</div>

		<div class="col-6">
			<input type="text" asp-for="Razrednik" class="form-control" />
		</div>

		<div class="col">
			<span class="text-danger" asp-validation-for="Razrednik"></span>
		</div>
	</div>

	<div class="row mb-3">
		<div class="col-2">
			<label asp-for="RazredBrojUcenika" class=" col-form-label">Broj učenika u razredu</label>
		</div>

		<div class="col-6">
			<input type="number" asp-for="RazredBrojUcenika" class="form-control" />
		</div>

		<div class="col">
			<span class="text-danger" asp-validation-for="RazredBrojUcenika"></span>
		</div>
	</div>
	
	<div class="row mb-3">
		<div class="col-2">
			
		</div>

		<div class="col-6">
			<input type="submit" class="btn btn-primary" value="Add" />
		</div>
	</div>

</form>


